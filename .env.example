# Core runtime
APP_NAME=local-vanna-ai
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Vanna 2 chat UI
VANNA_UI_TITLE=Local Vanna AI
VANNA_UI_SUBTITLE=Ask questions in natural language using the Vanna 2 chat interface.
VANNA_UI_CDN_URL=https://img.vanna.ai/vanna-components.js

# GLM / ZhipuAI
GLM_API_KEY=your-glm-api-key-here
GLM_MODEL=glm-4
GLM_EMBED_MODEL=embedding-2

# Optional: custom API URL (defaults to ZhipuAI's official endpoint)
# GLM_API_URL=

# Database
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vanna_local
DB_USER=vanna
DB_PASSWORD=vanna

# Bootstrap behavior
TRAIN_ON_START=false
INCLUDE_TRAINING_FILES_ON_START=false
ALLOW_BOOTSTRAP_SAMPLE_DATA=true

# Optional tuning
DB_STATEMENT_TIMEOUT_MS=0
MAX_RESULT_ROWS=200
VANNA_TOP_K=10
SSE_KEEPALIVE_SECONDS=15
GLM_TIMEOUT=120

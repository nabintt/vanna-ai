# Core runtime
APP_NAME=local-vanna-ai
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Optional: use a dedicated local embedding model instead of Chroma's default embedding backend.
# Example: OLLAMA_EMBED_MODEL=embeddinggemma
# OLLAMA_EMBED_MODEL=

# Database
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vanna_local
DB_USER=vanna
DB_PASSWORD=vanna

# Bootstrap behavior
TRAIN_ON_START=true
ALLOW_BOOTSTRAP_SAMPLE_DATA=true

# Optional tuning
MAX_RESULT_ROWS=200
VANNA_TOP_K=10
OLLAMA_TIMEOUT=120
OLLAMA_KEEP_ALIVE=15m
OLLAMA_NUM_CTX=4096
